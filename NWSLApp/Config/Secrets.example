//
//  Secrets.example  →  copy to  Secrets.swift  (gitignored)
//  NWSLApp
//
//  TEMPLATE — this file intentionally has NO `.swift` extension, so it is never
//  compiled. It documents the contract the real, gitignored `Secrets.swift`
//  must fulfil. To set the project up on a fresh clone:
//
//    1. Duplicate this file as `NWSLApp/Config/Secrets.swift`.
//    2. Rename the contents' values with your real Supabase credentials from
//       the dashboard → Project Settings → API.
//
//  `Secrets.swift` is gitignored. The anon key is a PUBLIC client key — the real
//  security boundary is Supabase Row-Level Security (each user can only touch
//  rows where `user_id = auth.uid()`), not the secrecy of this key. We still keep
//  it out of git as good hygiene and so the repo carries no project-specific URL.
//
//  Because both this template and the real file would define `enum Secrets`,
//  keeping this one as a non-`.swift` file avoids a duplicate-definition build
//  error — only `Secrets.swift` ever reaches the compiler.
//

enum Secrets {
    /// Supabase project URL, e.g. "https://abcdefgh.supabase.co"
    static let supabaseURL = "https://YOUR-PROJECT-REF.supabase.co"

    /// Supabase anon / public key (Project Settings → API → Project API keys → anon public).
    static let supabaseAnonKey = "YOUR-ANON-PUBLIC-KEY"
}
