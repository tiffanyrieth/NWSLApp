<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
	<!--
	  Game Center (GameKit) — Fan Zone leaderboards + achievements (0.3.9). Native
	  cross-player ranking on top of the real Supabase boards. Free; requires the
	  paid Developer Program (active). The leaderboard/achievement records are
	  created in App Store Connect (see the IDs in GameCenterIDs.swift); this
	  entitlement is what lets the build talk to Game Center. No Info.plist keys.
	-->
	<key>com.apple.developer.game-center</key>
	<true/>
	<!--
	  Push notifications (Tier 2 / server push, 0.4.x). `development` selects the
	  sandbox APNs environment for builds run from Xcode; Xcode automatically
	  swaps this to `production` when it archives a distribution build (TestFlight
	  / App Store), so this single value is correct for both. The match-watcher
	  Worker must send to the matching APNs host (api.sandbox.push.apple.com for a
	  dev build's token, api.push.apple.com for a TestFlight build's) — it picks
	  the host from a secret so we can flip without a code change.
	-->
	<key>aps-environment</key>
	<string>development</string>
	<!--
	  Time-Sensitive notifications (0.4.x rich match alerts). Lets live-match server
	  pushes (kickoff/goal/HT/FT) set `interruption-level: time-sensitive` so they
	  break through Focus/scheduled summary while a match is live — a stale match
	  alert is useless. Without this entitlement iOS silently downgrades the level.
	  Requires the capability enabled on the App ID in the Developer portal.
	-->
	<key>com.apple.developer.usernotifications.time-sensitive</key>
	<true/>
</dict>
</plist>
